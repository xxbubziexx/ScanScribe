version: '3.8'

services:
  scanscribe:
    build:
      context: .
      dockerfile: Dockerfile
    container_name: scanscribe
    restart: unless-stopped

    ports:
      - "0.0.0.0:8000:8000"

    volumes:
      # Configuration file (edit and restart to apply)
      - ./config.yml:/app/config.yml

      # Ingest directory — choose one:
      - ./ingest:/app/ingest                         # local drop folder
      # - /mnt/scanscribe/ingest:/app/ingest         # network share (NFS/SMB)

      # Whisper + NER models
      - ./models:/app/models

      # Persistent data
      - audio_storage:/app/audio_storage
      - ./logs:/app/logs
      - ./data:/app/data

      # Timezone sync from host
      - /etc/localtime:/etc/localtime:ro

    environment:
      - TZ=${TZ:-America/Chicago}

      # Security (set in .env)
      - SECRET_KEY=${SECRET_KEY}
      - ACCESS_TOKEN_EXPIRE_MINUTES=${ACCESS_TOKEN_EXPIRE_MINUTES:-1440}

      # Optional: bootstrap admin on empty DB
      # - SCANSCRIBE_DEFAULT_ADMIN_PASSWORD=${SCANSCRIBE_DEFAULT_ADMIN_PASSWORD}
      # - SCANSCRIBE_DEFAULT_ADMIN_USERNAME=${SCANSCRIBE_DEFAULT_ADMIN_USERNAME:-admin}
      # - SCANSCRIBE_DEFAULT_ADMIN_EMAIL=${SCANSCRIBE_DEFAULT_ADMIN_EMAIL:-admin@localhost}

      # Directories (match volume mounts above)
      - INGEST_DIR=/app/ingest
      - OUTPUT_DIR=/app/audio_storage
      - LOG_DIR=/app/logs
      - DB_PATH=/app/data/scanscribe.db
      - CONFIG_PATH=/app/config.yml

      # PyTorch CPU thread limits (set in .env or remove to use all cores)
      - OMP_NUM_THREADS=${OMP_NUM_THREADS:-4}
      - MKL_NUM_THREADS=${MKL_NUM_THREADS:-4}
      - TORCH_NUM_THREADS=${TORCH_NUM_THREADS:-4}

    # Resource limits — adjust to your hardware
    deploy:
      resources:
        limits:
          memory: 8G
        # cpus: '4'

    # Optional: GPU support (requires NVIDIA Docker runtime)
    # deploy:
    #   resources:
    #     reservations:
    #       devices:
    #         - driver: nvidia
    #           count: 1
    #           capabilities: [gpu]

    networks:
      - scanscribe_network

volumes:
  audio_storage:
    driver: local

networks:
  scanscribe_network:
    driver: bridge
